@@ -0,0 +1,254 @@
+/*!
+ * SportLab V6.3.6
+ * Framework CSS Premium - Foundation
+ * Pack 2
+ */
+
+/* =========================================================
+01. DESIGN TOKENS
+========================================================= */
+:root{
+ --sl-bg:#08101d;
+ --sl-surface:#111c2d;
+ --sl-surface-2:#162235;
+ --sl-text:#f8fafc;
+ --sl-muted:#94a3b8;
+ --sl-primary:#38bdf8;
+ --sl-secondary:#8b5cf6;
+ --sl-success:#22c55e;
+ --sl-warning:#f59e0b;
+ --sl-danger:#ef4444;
+ --sl-radius:18px;
+ --sl-gap:16px;
+ --sl-shadow:0 16px 40px rgba(0,0,0,.25);
+ --sl-transition:.2s ease;
+}
+
+/* =========================================================
+02. RESET
+========================================================= */
+*,*:before,*:after{box-sizing:border-box}
+html{scroll-behavior:smooth}
+body{
+ margin:0;
+ background:var(--sl-bg);
+ color:var(--sl-text);
+ font-family:Inter,system-ui,sans-serif;
+}
+img{max-width:100%;display:block}
+button,input,select,textarea{font:inherit}
+
+/* =========================================================
+03. LAYOUT
+========================================================= */
+.sl-container{width:min(1240px,calc(100% - 32px));margin:auto}
+.sl-grid{display:grid;gap:var(--sl-gap)}
+.sl-grid-2{grid-template-columns:repeat(2,minmax(0,1fr))}
+.sl-grid-3{grid-template-columns:repeat(3,minmax(0,1fr))}
+.sl-stack>*+*{margin-top:var(--sl-gap)}
+
+/* =========================================================
+04. SURFACES
+========================================================= */
+.sl-card,.sl-panel{
+ background:var(--sl-surface);
+ border:1px solid rgba(255,255,255,.08);
+ border-radius:var(--sl-radius);
+ box-shadow:var(--sl-shadow);
+ padding:20px;
+ transition:all var(--sl-transition);
+}
+.sl-card:hover{transform:translateY(-2px)}
+
+/* =========================================================
+05. BUTTONS
+========================================================= */
+.sl-button{
+ display:inline-flex;
+ align-items:center;
+ justify-content:center;
+ min-height:44px;
+ padding:0 18px;
+ border-radius:12px;
+ border:0;
+ cursor:pointer;
+ color:white;
+ background:linear-gradient(135deg,var(--sl-primary),#2563eb);
+}
+.sl-button.secondary{
+ background:linear-gradient(135deg,var(--sl-secondary),#6d28d9);
+}
+.sl-button.success{background:var(--sl-success)}
+.sl-button.warning{background:var(--sl-warning)}
+.sl-button.danger{background:var(--sl-danger)}
+
+/* =========================================================
+06. BADGES
+========================================================= */
+.sl-badge{
+ display:inline-block;
+ padding:5px 10px;
+ border-radius:999px;
+ font-size:.75rem;
+ font-weight:700;
+}
+.sl-success{background:#133a24;color:#86efac}
+.sl-warning{background:#3b2d11;color:#fde68a}
+.sl-danger{background:#3d1414;color:#fca5a5}
+
+/* =========================================================
+07. KPI
+========================================================= */
+.sl-kpi{
+ padding:16px;
+ border-radius:14px;
+ background:var(--sl-surface-2);
+}
+.sl-kpi-label{color:var(--sl-muted);font-size:.75rem}
+.sl-kpi-value{font-size:1.5rem;font-weight:800}
+
+/* =========================================================
+08. TABLES
+========================================================= */
+.sl-table{width:100%;border-collapse:collapse}
+.sl-table th,.sl-table td{
+ padding:12px;
+ border-bottom:1px solid rgba(255,255,255,.08);
+}
+
+/* =========================================================
+09. FORMS
+========================================================= */
+.sl-input,.sl-select,.sl-textarea{
+ width:100%;
+ padding:12px;
+ border-radius:12px;
+ border:1px solid rgba(255,255,255,.08);
+ background:#0d1728;
+ color:white;
+}
+
+/* =========================================================
+10. NAVIGATION
+========================================================= */
+.sl-sidebar{}
+.sl-topbar{}
+.sl-nav{}
+.sl-nav-item{}
+
+/* =========================================================
+11. MODULE THEMES
+========================================================= */
+[data-module="drawhunter"]{--sl-primary:#38bdf8;}
+[data-module="frenchflair"]{--sl-primary:#a855f7;}
+
+/* =========================================================
+12. TRANSITION LAYER
+========================================================= */
+
+/* Legacy mapping */
+.analysis-card{ }
+.dashboard-card{ }
+.prediction-card{ }
+
+/* These legacy classes will progressively receive
+   .sl-card in Pack 3 before removal in Pack 4. */
+
+/* =========================================================
+13. RESPONSIVE
+========================================================= */
+@media(max-width:768px){
+ .sl-grid-2,.sl-grid-3{grid-template-columns:1fr}
+ .sl-container{width:min(100% - 20px,100%)}
+}
+/* =========================================================
+14. PACK 3 — MIGRATED VIEW COMPONENTS
+========================================================= */
+.sl-app-root{width:min(100% - 28px,1240px);margin:0 auto;padding:88px 0 32px}
+.sl-page{min-width:0}
+.sl-stack{display:grid;gap:var(--sl-gap)}
+.sl-stack-lg{gap:24px}
+.sl-page-section{margin-bottom:20px}
+.sl-section{display:grid;gap:16px}
+.sl-section-header{display:flex;align-items:center;justify-content:space-between;gap:16px}
+.sl-page-header{display:flex;align-items:flex-start;justify-content:space-between;gap:20px}
+.sl-page-title,.sl-section-title{margin:0}
+.sl-muted{color:var(--sl-muted)}
+.sl-label{color:var(--sl-muted);font-size:.75rem;font-weight:800;text-transform:uppercase;letter-spacing:.06em}
+.sl-positive{color:#86efac}.sl-negative{color:#fca5a5}.sl-value{color:#67e8f9}
+.sl-button-reset{border:0;background:none;color:inherit;padding:0}
+.sl-button-primary{background:linear-gradient(135deg,var(--sl-primary),#2563eb)}
+.sl-button-secondary{background:linear-gradient(135deg,var(--sl-secondary),#6d28d9)}
+.sl-card-compact{padding:14px}
+.sl-kpi-grid{display:grid;grid-template-columns:repeat(4,minmax(0,1fr));gap:14px}
+.sl-kpi-card{padding:16px;border:1px solid rgba(255,255,255,.08);border-radius:14px;background:var(--sl-surface-2)}
+.sl-table-wrap{overflow-x:auto;border-radius:14px}
+.sl-empty-state{text-align:center;padding:32px 20px}
+.sl-state{display:flex;align-items:flex-start;gap:12px}
+.sl-summary{overflow:hidden}
+.sl-analysis-card{min-width:0}
+
+/* Navigation */
+.sl-topbar{position:fixed;inset:0 0 auto 0;z-index:1000;min-height:68px;display:flex;align-items:center;justify-content:space-between;padding:12px max(16px,calc((100vw - 1240px)/2));border-bottom:1px solid rgba(255,255,255,.08);background:rgba(8,16,29,.88);backdrop-filter:blur(18px)}
+.sl-brand{display:flex;align-items:center;gap:10px;font-weight:900;font-size:1.08rem;cursor:pointer}
+.sl-menu-toggle{display:grid;width:44px;height:44px;place-content:center;gap:5px;border:1px solid rgba(255,255,255,.10);border-radius:12px;background:var(--sl-surface);color:#fff}
+.sl-menu-toggle span{display:block;width:20px;height:2px;border-radius:99px;background:currentColor}
+.sl-mobile-menu{position:fixed;top:76px;right:16px;z-index:1010;display:grid;width:min(340px,calc(100vw - 32px));gap:8px;padding:12px;border:1px solid rgba(255,255,255,.10);border-radius:18px;background:rgba(17,28,45,.98);box-shadow:var(--sl-shadow);transform:translateY(-8px);opacity:0;pointer-events:none;transition:opacity var(--sl-transition),transform var(--sl-transition)}
+.sl-mobile-menu.menu-open,.sl-mobile-menu.is-open{transform:none;opacity:1;pointer-events:auto}
+.sl-nav-item{display:grid;grid-template-columns:auto 1fr auto;align-items:center;gap:12px;width:100%;min-height:48px;padding:10px 12px;border:0;border-radius:12px;background:transparent;color:var(--sl-text);text-align:left;cursor:pointer}
+.sl-nav-item:hover,.sl-nav-item.is-active,.sl-nav-item.nav-active{background:rgba(56,189,248,.10)}
+.sl-menu-backdrop{position:fixed;inset:68px 0 0;z-index:1005;background:rgba(0,0,0,.45);opacity:0;pointer-events:none}
+.sl-menu-backdrop.menu-open,.sl-menu-backdrop.is-open{opacity:1;pointer-events:auto}
+
+/* Dashboard */
+.sl-hero{position:relative;overflow:hidden;padding:28px}
+.sl-hero:after{position:absolute;right:-80px;top:-100px;width:260px;height:260px;border-radius:50%;content:"";background:radial-gradient(circle,rgba(56,189,248,.22),transparent 68%)}
+.sl-module-card{display:flex;min-height:280px;flex-direction:column}
+.premium-module-footer{margin-top:auto}
+.premium-module-stats,.premium-sync-grid{display:grid;grid-template-columns:repeat(3,minmax(0,1fr));gap:10px}
+.premium-module-stat{padding:12px;border-radius:12px;background:rgba(255,255,255,.04)}
+.premium-dashboard-hero-badges{display:flex;flex-wrap:wrap;gap:8px;margin-top:16px}
+.premium-dashboard-kpis{margin-top:2px}
+.premium-alert-list{display:grid;gap:10px}
+
+/* Analysis views */
+.analysis-summary__grid,.analysis-kpis{display:grid;grid-template-columns:repeat(4,minmax(0,1fr));gap:12px}
+.analysis-grid{align-items:start}
+.analysis-card{display:flex;flex-direction:column;overflow:hidden}
+.analysis-card__header,.analysis-card__footer{padding:18px}
+.analysis-matchup{display:grid;grid-template-columns:minmax(0,1fr) auto minmax(0,1fr);align-items:center;gap:12px;padding:20px 18px}
+.analysis-team--away{text-align:right}
+.analysis-vs{display:grid;width:40px;height:40px;place-items:center;border-radius:50%;background:rgba(255,255,255,.06)}
+.analysis-kpis{grid-template-columns:repeat(3,minmax(0,1fr));padding:0 18px 18px}
+.analysis-progress{padding:0 18px 18px}
+.analysis-progress__track{height:8px;overflow:hidden;border-radius:99px;background:rgba(255,255,255,.08)}
+.analysis-progress__track>span{display:block;height:100%;border-radius:inherit;background:linear-gradient(90deg,var(--sl-primary),var(--sl-secondary))}
+.analysis-market,.analysis-total,.analysis-range,.analysis-state--inline{margin:0 18px 18px;padding:14px;border-radius:14px;background:rgba(255,255,255,.04)}
+.analysis-total{text-align:center}
+.analysis-bet-panel{display:grid;gap:12px;padding:14px;border-radius:14px;background:rgba(34,197,94,.07)}
+.analysis-button{width:100%}
+.analysis-field{display:grid;gap:7px}.analysis-field__control{display:grid;grid-template-columns:1fr auto;border:1px solid rgba(255,255,255,.08);border-radius:12px;background:#0d1728}.analysis-field__control input{width:100%;border:0;background:transparent;color:#fff;padding:12px;outline:0}.analysis-field__control span{padding:12px;color:var(--sl-muted)}
+
+/* Portfolio and journal */
+.portfolio-summary{grid-template-columns:repeat(4,minmax(0,1fr))}
+.portfolio-stat h3{margin:.35rem 0 0}
+.journal-list{gap:14px}.journal-card{padding:18px}.journal-card-header,.journal-card-footer{display:flex;align-items:flex-start;justify-content:space-between;gap:14px}.journal-card-metrics,.journal-financial-grid{display:grid;grid-template-columns:repeat(4,minmax(0,1fr));gap:10px}.journal-metric,.journal-financial-item{padding:12px;border-radius:12px;background:rgba(255,255,255,.04)}
+
+/* Status mappings */
+.sl-badge-info,.badge-info{background:rgba(59,130,246,.15);color:#93c5fd}
+.sl-badge-success,.badge-success{background:rgba(34,197,94,.15);color:#86efac}
+.sl-badge-warning,.badge-warning{background:rgba(245,158,11,.15);color:#fcd34d}
+.sl-badge-danger,.badge-danger{background:rgba(239,68,68,.15);color:#fca5a5}
+.sl-badge-neutral,.badge-secondary{background:rgba(148,163,184,.12);color:#cbd5e1}
+
+@media(max-width:900px){
+ .sl-kpi-grid,.portfolio-summary,.analysis-summary__grid{grid-template-columns:repeat(2,minmax(0,1fr))}
+ .premium-module-stats,.premium-sync-grid,.journal-card-metrics,.journal-financial-grid{grid-template-columns:repeat(2,minmax(0,1fr))}
+}
+@media(max-width:640px){
+ .sl-app-root{width:min(100% - 20px,1240px);padding-top:80px}
+ .sl-page-header,.sl-section-header,.journal-card-header,.journal-card-footer{align-items:stretch;flex-direction:column}
+ .sl-kpi-grid,.portfolio-summary,.analysis-summary__grid,.analysis-kpis,.premium-module-stats,.premium-sync-grid,.journal-card-metrics,.journal-financial-grid{grid-template-columns:1fr}
+ .analysis-matchup{grid-template-columns:1fr;text-align:center}.analysis-team--away{text-align:center}.analysis-vs{margin:auto}
+ .sl-hero{padding:20px}
+}
