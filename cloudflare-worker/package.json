{
  "name": "sportlab-cloud-sync-worker",
  "version": "7.0.1",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "wrangler dev",
    "deploy": "wrangler deploy",
    "db:create": "wrangler d1 create sportlab-sync-db --jurisdiction eu",
    "db:migrate:local": "wrangler d1 migrations apply sportlab-sync-db --local",
    "db:migrate:remote": "wrangler d1 migrations apply sportlab-sync-db --remote",
    "test": "node --test",
    "check": "node --check src/index.js && node --check src/auth.js && node --check src/cors.js && node --check src/db.js && node --check src/http.js && node --check src/router.js"
  },
  "devDependencies": {
    "wrangler": "^4.28.0"
  }
}
